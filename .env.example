# Application
NODE_ENV=production
APP_NAME=Ops Solutions
APP_URL=http://localhost:3210
WEB_PORT=3210
API_PORT=3211
LOG_LEVEL=info

# PostgreSQL
POSTGRES_DB=ops_solutions
POSTGRES_USER=ops_solutions
POSTGRES_PASSWORD=replace_with_a_long_random_password
DATABASE_URL=postgresql://ops_solutions:replace_with_a_long_random_password@postgres:5432/ops_solutions

# Redis
REDIS_URL=redis://redis:6379

# Security placeholders - required before connecting real customers
AUTH_SECRET=replace_with_at_least_32_random_characters
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_characters

# HubSpot OAuth - leave empty until the app is created
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=

# AI provider - leave empty during platform bootstrap
AI_API_KEY=
AI_MODEL=
