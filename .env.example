# Application
NODE_ENV=production
APP_NAME=Ops Solutions
APP_URL=https://dashboard.example.com
WEB_PORT=3210
API_PORT=3211
LOG_LEVEL=info

# Temporary bootstrap administration
# Generate with: openssl rand -base64 48
ADMIN_API_KEY=replace_with_a_long_random_value

# PostgreSQL
POSTGRES_DB=ops_solutions
POSTGRES_USER=ops_solutions
POSTGRES_PASSWORD=replace_with_a_long_random_password
DATABASE_URL=postgresql://ops_solutions:replace_with_a_long_random_password@postgres:5432/ops_solutions

# Redis
REDIS_URL=redis://redis:6379

# OAuth token encryption
# Generate 32 bytes as base64 with: openssl rand -base64 32
ENCRYPTION_KEY=replace_with_a_32_byte_base64_key

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://dashboard.example.com/api/v1/hubspot/oauth/callback
HUBSPOT_SUCCESS_REDIRECT_URI=https://dashboard.example.com/setup
HUBSPOT_API_BASE_URL=https://api.hubapi.com
HUBSPOT_TOKEN_URL=https://api.hubapi.com/oauth/v1/token

# Override only when the HubSpot app uses a different scope set
HUBSPOT_SCOPES=oauth crm.objects.contacts.read crm.objects.companies.read crm.objects.deals.read crm.objects.owners.read crm.schemas.contacts.read crm.schemas.companies.read crm.schemas.deals.read
HUBSPOT_OPTIONAL_SCOPES=crm.objects.calls.read crm.objects.meetings.read crm.objects.tasks.read crm.schemas.custom.read

# CRM sync worker
HUBSPOT_SYNC_OBJECTS=contacts,companies,deals,calls,meetings,tasks
HUBSPOT_SYNC_PAGE_SIZE=100
HUBSPOT_REQUEST_DELAY_MS=240
SYNC_SCHEDULER_INTERVAL_MS=300000
SYNC_INCREMENTAL_INTERVAL_MINUTES=15
SYNC_FULL_RECONCILIATION_HOURS=24
SYNC_MAX_PAGES_PER_RUN=500

# AI provider - not required for deterministic semantic mapping
AI_API_KEY=
AI_MODEL=
